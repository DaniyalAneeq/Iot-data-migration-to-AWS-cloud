###############################################################################
# Terraform
###############################################################################
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl

# Keep example var files; ignore any real/secret ones.
*.auto.tfvars
secrets.tfvars
*.secret.tfvars

###############################################################################
# Secrets & credentials
###############################################################################
.env
.env.*
*.pem
*.key
*.p8
aws.json
credentials
.pub
secrets.toml
###############################################################################
# Python
###############################################################################
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
*.egg-info/

###############################################################################
# Build artifacts
###############################################################################
build/
dist/
*.zip

###############################################################################
# Local data (keep structure via .gitkeep)
###############################################################################
data/raw/*
data/processed/*
data/curated/*
!data/**/.gitkeep
!data/README.md

###############################################################################
# OS / IDE
###############################################################################
.DS_Store
Thumbs.db
.idea/
.vscode/
